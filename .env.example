# AgentRouter Configuration
# Copy this file to .env and fill in your values

# Database
AR_DATABASE_URL=postgresql+asyncpg://agentrouter:agentrouter@localhost:5432/agentrouter

# Logging
AR_LOG_LEVEL=INFO

# Development mode (bypasses auth, uses dev keys below)
AR_DEV_MODE=true

# Provider API Keys (set the ones you have)
AR_DEV_OPENAI_API_KEY=sk-your-openai-key
AR_DEV_ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
AR_DEV_GEMINI_API_KEY=your-gemini-key
AR_DEV_GROQ_API_KEY=gsk_your-groq-key
AR_DEV_MISTRAL_API_KEY=your-mistral-key
AR_DEV_COHERE_API_KEY=your-cohere-key
AR_DEV_TOGETHER_API_KEY=your-together-key

# Provider Base URLs (defaults shown, override for proxies/custom endpoints)
# AR_OPENAI_BASE_URL=https://api.openai.com/v1
# AR_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# AR_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# AR_GROQ_BASE_URL=https://api.groq.com/openai/v1
# AR_MISTRAL_BASE_URL=https://api.mistral.ai/v1
# AR_COHERE_BASE_URL=https://api.cohere.com/v2
# AR_TOGETHER_BASE_URL=https://api.together.xyz/v1

# Health checks
# AR_HEALTH_CHECK_INTERVAL=30

# Routing
AR_ROUTING_ENABLED=true
# AR_ROUTING_ALLOWED_PROVIDERS=openai,anthropic
# AR_ROUTING_DENIED_PROVIDERS=
# AR_ROUTING_TIER_FLOOR=
# AR_ROUTING_TIER_CEILING=
