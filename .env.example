# Kestrel Configuration
# Copy this file to .env and fill in your values

# Database
KS_DATABASE_URL=postgresql+asyncpg://kestrel:kestrel@localhost:5432/kestrel

# Logging
KS_LOG_LEVEL=INFO

# Development mode (bypasses auth, uses dev keys below)
KS_DEV_MODE=true

# ---------------------------------------------------------------------------
# Provider API Keys
# REQUIRED: Set at least ONE provider key to use the proxy.
# Groq offers a free tier — easiest way to test: https://console.groq.com
# ---------------------------------------------------------------------------
KS_DEV_OPENAI_API_KEY=
KS_DEV_ANTHROPIC_API_KEY=
KS_DEV_GEMINI_API_KEY=
KS_DEV_GROQ_API_KEY=
KS_DEV_XAI_API_KEY=
KS_DEV_MISTRAL_API_KEY=
KS_DEV_COHERE_API_KEY=
KS_DEV_TOGETHER_API_KEY=

# Provider Base URLs (defaults shown, override for proxies/custom endpoints)
# KS_OPENAI_BASE_URL=https://api.openai.com/v1
# KS_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# KS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# KS_GROQ_BASE_URL=https://api.groq.com/openai/v1
# KS_XAI_BASE_URL=https://api.x.ai/v1
# KS_MISTRAL_BASE_URL=https://api.mistral.ai/v1
# KS_COHERE_BASE_URL=https://api.cohere.com/v2
# KS_TOGETHER_BASE_URL=https://api.together.xyz/v1

# Health checks
# KS_HEALTH_CHECK_INTERVAL=30

# Routing
KS_ROUTING_ENABLED=true
# KS_ROUTING_ALLOWED_PROVIDERS=openai,anthropic
# KS_ROUTING_DENIED_PROVIDERS=
# KS_ROUTING_TIER_FLOOR=
# KS_ROUTING_TIER_CEILING=
